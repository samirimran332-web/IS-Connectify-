{
  "entities": {
    "NewsItem": {
      "title": "News Item",
      "description": "A news article generated by AI and uploaded by a user.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the news article." },
        "content": { "type": "string", "description": "The content of the news article." },
        "authorName": { "type": "string", "description": "The name of the author." },
        "authorUid": { "type": "string", "description": "The UID of the author." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The time the news was created." },
        "imageUrl": { "type": "string", "description": "Optional image URL for the news." }
      },
      "required": ["title", "content", "authorName", "authorUid", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "The profile details of a user.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "description": "The user's email address." },
        "photoURL": { "type": "string", "description": "The user's profile picture URL." },
        "bio": { "type": "string", "description": "A short bio about the user." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The user's role." },
        "studentClass": { "type": "string", "description": "The class the student is in." },
        "department": { "type": "string", "enum": ["Science", "Commerce", "Arts", "None"], "description": "The student's department." }
      },
      "required": ["displayName", "email"]
    },
    "Task": {
      "title": "Study Task",
      "description": "A personal study task for a student.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the task." },
        "description": { "type": "string", "description": "A detailed description of the task." },
        "dueDate": { "type": "string", "format": "date-time", "description": "The due date for the task." },
        "completed": { "type": "boolean", "description": "Whether the task is completed." },
        "userId": { "type": "string", "description": "The UID of the user who owns the task." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the task was created." }
      },
      "required": ["title", "userId", "completed"]
    },
    "StudySession": {
      "title": "Study Session",
      "description": "A past study session with the AI assistant.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who owns the session." },
        "title": { "type": "string", "description": "A short title for the session." },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "ai"] },
              "content": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the session was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the session was last updated." }
      },
      "required": ["userId", "title", "messages", "createdAt"]
    },
    "StudyGroup": {
      "title": "Study Group",
      "description": "A group of students studying together.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the group." },
        "description": { "type": "string", "description": "A description of the group's goals." },
        "createdBy": { "type": "string", "description": "The UID of the creator." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the group was created." },
        "inviteCode": { "type": "string", "description": "A unique code to join the group." }
      },
      "required": ["name", "createdBy", "createdAt", "inviteCode"]
    },
    "GroupMember": {
      "title": "Group Member",
      "description": "A member of a study group.",
      "type": "object",
      "properties": {
        "groupId": { "type": "string", "description": "The ID of the group." },
        "userId": { "type": "string", "description": "The UID of the user." },
        "role": { "type": "string", "enum": ["owner", "member"], "description": "The user's role in the group." },
        "joinedAt": { "type": "string", "format": "date-time", "description": "When the user joined." }
      },
      "required": ["groupId", "userId", "role", "joinedAt"]
    },
    "GroupResource": {
      "title": "Group Resource",
      "description": "A shared resource (note or task) in a group.",
      "type": "object",
      "properties": {
        "groupId": { "type": "string", "description": "The ID of the group." },
        "title": { "type": "string", "description": "The title of the resource." },
        "content": { "type": "string", "description": "The content or description of the resource." },
        "type": { "type": "string", "enum": ["note", "task"], "description": "The type of resource." },
        "completed": { "type": "boolean", "description": "For tasks, whether it is completed." },
        "createdBy": { "type": "string", "description": "The UID of the creator." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When it was shared." }
      },
      "required": ["groupId", "title", "type", "createdBy", "createdAt"]
    }
  },
  "firestore": {
    "/news/{newsId}": {
      "schema": "NewsItem",
      "description": "Collection of news items."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Personal study tasks for users."
    },
    "/study_sessions/{sessionId}": {
      "schema": "StudySession",
      "description": "Past study sessions for users."
    },
    "/groups/{groupId}": {
      "schema": "StudyGroup",
      "description": "Collection of study groups."
    },
    "/group_members/{memberId}": {
      "schema": "GroupMember",
      "description": "Mapping of users to groups."
    },
    "/group_resources/{resourceId}": {
      "schema": "GroupResource",
      "description": "Shared resources within groups."
    }
  }
}
